# Dealio backend — environment template (SAFE TO COMMIT: no real values here).
# Copy to `.env` for local dev. Real per-environment secrets live in AWS Secrets
# Manager / SSM Parameter Store (NOT in git, NOT in GitHub Secrets). See
# docs/DEPLOYMENT.md for the dev/prod resource map.

# --- Core ---
NODE_ENV=development                 # development | production
PORT=8090

# --- Database (per-environment RDS) ---
# postgresql://<user>:<password>@<rds-endpoint>:5432/<db>?schema=public&sslmode=require
DATABASE_URL=

# --- Redis (OTP codes + send rate-limiting) ---
# Optional locally (falls back to in-memory). REQUIRED in any environment that
# runs more than one backend instance, since OTP state must be shared.
# redis://localhost:6379  or  rediss://<host>:6379 for TLS (e.g. ElastiCache)
REDIS_URL=

# --- Auth ---
JWT_SECRET=                          # long random string; different per environment
GOOGLE_CLIENT_ID=

# --- CORS / links (per-environment frontend origin) ---
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# --- AI ---
ANTHROPIC_API_KEY=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- WhatsApp (Meta Cloud API) — optional ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_LANG=en
WHATSAPP_OTP_TEMPLATE=
# Webhook (callback URL: https://<backend-domain>/api/whatsapp/webhook)
WHATSAPP_VERIFY_TOKEN=                # any long random string; must match Meta's "Verify token"
WHATSAPP_APP_SECRET=                  # Meta App → Settings → Basic; validates inbound webhook signatures

# --- SMS OTP (Twilio or MSG91) — optional ---
SMS_PROVIDER=                        # twilio | msg91 (blank = WhatsApp/mock fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
