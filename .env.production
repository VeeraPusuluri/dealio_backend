# ── Production env template — set these on the AWS ECS task definition ──────
# (Container → Environment; put secrets in SSM Parameter Store / Secrets
# Manager and reference them as "secrets" in the task definition.)

# RDS PostgreSQL connection string
DATABASE_URL=postgresql://postgres:DealioProdPass2024@dealio-prod-db.c0h2aecw6nd7.us-east-1.rds.amazonaws.com:5432/postgres?schema=public
# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Without this the app falls back to a hardcoded dev secret — never deploy without it.
JWT_SECRET=dealio_prod_secret_2024_x92

# Server
NODE_ENV=production
PORT=8090

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://REPLACE_WITH_FRONTEND_DOMAIN

# Public URL of the frontend — used to build links sent to users (e.g. CP invites)
FRONTEND_URL=https://REPLACE_WITH_FRONTEND_DOMAIN

# Google OAuth (login)
GOOGLE_CLIENT_ID=1013744675613-5spva6h3eflij6vvofvjor875iiq9s63.apps.googleusercontent.com

# Anthropic — AI chat (/api/ai)
ANTHROPIC_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Email via SMTP (emailService) — leave unset to disable outgoing email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp via Meta Cloud API — off unless both TOKEN and PHONE_ID are set.
# When set, login/signup OTPs are delivered on WhatsApp (preferred channel).
# TOKEN must be a permanent System User token (whatsapp_business_messaging),
# not the 24h temporary token from the Meta app dashboard.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_LANG=en
# Authentication-category template (Meta Business Manager → Templates →
# Authentication, with copy-code button). {{1}} is the 6-digit code.
WHATSAPP_OTP_TEMPLATE=dealio_otp

# SMS fallback for OTP (used when WhatsApp is unset or a send fails).
# Configure one: Twilio (TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN/TWILIO_FROM)
# or MSG91 (MSG91_AUTH_KEY/MSG91_TEMPLATE_ID); SMS_PROVIDER forces the choice.
# With neither WhatsApp nor SMS set, OTPs appear in server logs only and are
# echoed to the client outside production.
SMS_PROVIDER=

# File uploads — for production use S3 (local disk is ephemeral on Fargate;
# mount an EFS volume at /app/uploads as a stopgap)
# UPLOAD_BUCKET=your-s3-bucket
